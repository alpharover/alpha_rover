{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "degrade_policies",
  "type": "object",
  "properties": {
    "levels": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "video_fps": { "type": "integer", "minimum": 0 },
          "video_bitrate": { "type": "integer", "minimum": 0 },
          "lidar_hz": { "type": "integer", "minimum": 0 },
          "mapping": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "triggers": {
      "type": "object",
      "properties": {
        "slo_p95_cmd_ms": { "type": "number", "minimum": 0 },
        "slo_p95_map_ms": { "type": "number", "minimum": 0 },
        "slo_p95_video_ms": { "type": "number", "minimum": 0 },
        "rtt_ms": { "type": "array", "items": { "type": "number", "minimum": 0 } },
        "loss_pct": { "type": "array", "items": { "type": "number", "minimum": 0 } }
      },
      "additionalProperties": true
    }
  },
  "required": ["levels", "triggers"],
  "additionalProperties": true
}

