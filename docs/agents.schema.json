{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AGENTS Front-Matter v1",
  "type": "object",
  "required": [
    "agent",
    "component_type",
    "status",
    "version",
    "updated",
    "owner",
    "links",
    "dependencies",
    "provides",
    "configs",
    "runbooks"
  ],
  "properties": {
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "component_type": {
      "type": "string",
      "enum": [
        "ros2_package",
        "config",
        "deploy",
        "docs",
        "tooling"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "alpha",
        "beta",
        "stable",
        "deprecated"
      ]
    },
    "version": {
      "type": "string"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "owner": {
      "type": "string"
    },
    "links": {
      "type": "object",
      "required": [
        "roadmap"
      ],
      "properties": {
        "roadmap": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "readme": {
          "type": "string"
        },
        "docs": {
          "type": "string"
        }
      }
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "internal": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "external": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provides": {
      "type": "object",
      "properties": {
        "topics_pub": {
          "type": "array"
        },
        "topics_sub": {
          "type": "array"
        },
        "services": {
          "type": "array"
        },
        "actions": {
          "type": "array"
        }
      }
    },
    "configs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runbooks": {
      "type": "object"
    }
  }
}